# Caddy: отдаёт собранный клиент и проксирует API + WebSocket на Colyseus.
# Сертификат Let's Encrypt выпускается и продлевается автоматически, редирект
# с HTTP на HTTPS Caddy тоже включает сам — certbot и крон не нужны.
#
# Перед установкой заменить EXAMPLE.COM на реальный домен (в обеих строках).

EXAMPLE.COM, www.EXAMPLE.COM {
	root * /home/deploy/crusade-deck/client/dist
	encode zstd gzip

	# Сокет Colyseus живёт по адресу /{processId}/{roomId} — то есть в корне,
	# рядом со статикой. Отличить его от запроса файла можно только по заголовкам
	# апгрейда, поэтому этот матчер должен стоять первым.
	@websocket {
		header Connection *Upgrade*
		header Upgrade    websocket
	}
	handle @websocket {
		reverse_proxy 127.0.0.1:2567
	}

	# HTTP-эндпоинты сервера. /matchmake — внутренний путь Colyseus, по нему клиент
	# резервирует место перед подключением сокета; без него игра не создаст комнату.
	handle /matchmake* {
		reverse_proxy 127.0.0.1:2567
	}
	handle /accounts* {
		reverse_proxy 127.0.0.1:2567
	}
	handle /rooms* {
		reverse_proxy 127.0.0.1:2567
	}
	handle /health {
		reverse_proxy 127.0.0.1:2567
	}

	# Всё остальное — статика клиента, с фоллбэком на index.html (роутинг по /r/<код>).
	handle {
		try_files {path} /index.html
		file_server
	}
}
