# В dev клиент и сервер живут на разных портах, поэтому автоопределение адреса
# из window.location (src/serverUrl.ts) здесь не подходит — указываем явно.
# В проде этих переменных нет: всё идёт относительно текущего origin через Caddy.
VITE_SERVER_URL=ws://localhost:2567
VITE_HTTP_URL=http://localhost:2567
